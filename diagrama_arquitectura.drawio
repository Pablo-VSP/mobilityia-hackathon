<mxfile host="app.diagrams.net">
  <diagram name="ADO Intelligence MVP Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- CLIENT -->
        <mxCell id="client" value="Cliente / Usuario&#xa;Dashboard (QuickSight / Streamlit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc" vertex="1" parent="1">
          <mxGeometry x="850" y="300" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- FIREWALL -->
        <mxCell id="firewall" value="AWS WAF / Firewall" style="rounded=1;fillColor=#f8cecc" vertex="1" parent="1">
          <mxGeometry x="700" y="300" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- VPC -->
        <mxCell id="vpc" value="VPC (us-east-1)" style="swimlane;fillColor=#e1d5e7" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="420" height="450" as="geometry"/>
        </mxCell>

        <!-- PUBLIC SUBNET -->
        <mxCell id="public_subnet" value="Public Subnet" style="swimlane;fillColor=#fff2cc" vertex="1" parent="vpc">
          <mxGeometry x="10" y="10" width="400" height="150" as="geometry"/>
        </mxCell>

        <!-- PRIVATE SUBNET -->
        <mxCell id="private_subnet" value="Private Subnet" style="swimlane;fillColor=#d5e8d4" vertex="1" parent="vpc">
          <mxGeometry x="10" y="170" width="400" height="260" as="geometry"/>
        </mxCell>

        <!-- LAMBDA -->
        <mxCell id="lambda" value="AWS Lambda&#xa;Simulador tiempo real" style="rounded=1;fillColor=#ffe6cc" vertex="1" parent="public_subnet">
          <mxGeometry x="40" y="40" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- DYNAMODB -->
        <mxCell id="dynamo" value="DynamoDB&#xa;Estado en tiempo real" style="shape=cylinder;fillColor=#d5e8d4" vertex="1" parent="private_subnet">
          <mxGeometry x="40" y="40" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- S3 -->
        <mxCell id="s3" value="Amazon S3&#xa;Data Lake + Knowledge Base" style="shape=cylinder;fillColor=#fff2cc" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- BEDROCK -->
        <mxCell id="bedrock" value="Amazon Bedrock AgentCore" style="rounded=1;fillColor=#e1d5e7" vertex="1" parent="private_subnet">
          <mxGeometry x="220" y="20" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- AGENTS -->
        <mxCell id="agent1" value="Microservicio&#xa;Agente Combustible" style="rounded=1;fillColor=#dae8fc" vertex="1" parent="private_subnet">
          <mxGeometry x="220" y="100" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="agent2" value="Microservicio&#xa;Agente Mantenimiento" style="rounded=1;fillColor=#dae8fc" vertex="1" parent="private_subnet">
          <mxGeometry x="220" y="180" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- SAGEMAKER -->
        <mxCell id="sagemaker" value="SageMaker Endpoint&#xa;Predicción fallas" style="rounded=1;fillColor=#f5f5f5" vertex="1" parent="private_subnet">
          <mxGeometry x="40" y="150" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- CLOUDWATCH -->
        <mxCell id="cloudwatch" value="CloudWatch Logs" style="rounded=1;fillColor=#f5f5f5" vertex="1" parent="1">
          <mxGeometry x="300" y="580" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- IAM -->
        <mxCell id="iam" value="IAM Roles & Policies" style="rounded=1;fillColor=#f5f5f5" vertex="1" parent="1">
          <mxGeometry x="500" y="580" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- CONNECTIONS -->
        <mxCell id="c1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="client" target="firewall">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="firewall" target="lambda">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="lambda" target="dynamo">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="s3" target="lambda">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="dynamo" target="bedrock">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="bedrock" target="agent1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c7" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="bedrock" target="agent2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c8" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="agent2" target="sagemaker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c9" style="edgeStyle=orthogonalEdgeStyle;endArrow=block" edge="1" parent="1" source="bedrock" target="client">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>